{% style %}
  .pl--icon-{{ block.id }} {
      width: auto;
      height: {{ block.settings.height |  abs |  append: 'px' }};
      aspect-ratio: {{ block.settings.aspect_ratio }};
      object-fit: contain;

      padding-top: {{ block.settings.padding_top |  abs |  append: 'px' }};
      padding-bottom: {{ block.settings.padding_bottom |  abs |  append: 'px' }};
      padding-left: {{ block.settings.padding_left |  abs |  append: 'px' }};
      padding-right: {{ block.settings.padding_right |  abs |  append: 'px' }};

      color: {{ block.settings.color }};
  }

  @media (max-width: 768px) {
      .pl--icon-{{ block.id }} {
          height: {{ block.settings.height_mob |  abs |  append: 'px' }};
          aspect-ratio: {{ block.settings.aspect_ratio_mob }};

          padding-top: {{ block.settings.padding_top_mob |  abs |  append: 'px' }};
          padding-bottom: {{ block.settings.padding_bottom_mob |  abs |  append: 'px' }};
          padding-left: {{ block.settings.padding_left_mob |  abs |  append: 'px' }};
          padding-right: {{ block.settings.padding_right_mob |  abs |  append: 'px' }};
      }
  }
{% endstyle %}

<div {{ block.shopify_attributes }} style="line-height: 0;">
  {% capture icon_class %}pl--icon-{{ block.id }}{% endcapture %}
  {% if block.settings.image_upload != blank %}
    {{
      block.settings.image_upload
      | image_url: width: 500
      | image_tag: widths: '50, 100, 200, 300, 400, 500', class: icon_class
    }}
  {% elsif block.settings.svg_icon != blank %}
    <div class="pl--icon-{{ block.id }}">
      {{ block.settings.svg_icon }}
    </div>
  {% else %}
    {% assign placeholder = block.settings.placeholder | default: 'pl--icon-placeholder.svg' %}
    {% comment %} Render placeholder icon {% endcomment %}
    <img
      src="{{ placeholder | asset_url }}"
      alt="Placeholder icon"
      loading="lazy"
      width="100%"
      height="100%"
      class="{{ icon_class }}"
    >
  {% endif %}
</div>

{% schema %}
{
  "name": "Icon",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Customize the icon to your liking. Need help? Check our [documentation](https://www.pentlibrary.com/docs)."
