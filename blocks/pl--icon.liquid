        }
      ]
    },
    {
      "type": "header",
      "content": "Padding",
      "info": "All values in pixels"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Top",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Bottom",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "number",
      "id": "padding_left",
      "label": "Left",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "number",
      "id": "padding_right",
      "label": "Right",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "header",
      "content": "📱 Mobile"
    },
    {
      "type": "header",
      "content": "📱 Size"
    },
    {
      "type": "range",
      "id": "height_mob",
      "label": "Height",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mob",
      "label": "Aspect Ratio",
      "default": "auto",
      "options": [
        {
          "label": "Original",
          "value": "auto"
        },
        {
          "label": "Square",
          "value": "1/1"
        }
      ]
    },
    {
      "type": "header",
      "content": "📱 Padding",
      "info": "All values in pixels"
    },
    {
      "type": "number",
      "id": "padding_top_mob",
      "label": "Top",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "number",
      "id": "padding_bottom_mob",
      "label": "Bottom",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "number",
      "id": "padding_left_mob",
      "label": "Left",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "number",
      "id": "padding_right_mob",
      "label": "Right",
      "placeholder": "Enter a value in pixels"
    },
    {
      "type": "header",
      "content": "⚙️ Advanced"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Placeholder",
      "placeholder": "Default setting"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Class",
      "info": "For developers: Add space-separated CSS classes. See our [docs](https://www.pentlibrary.com/docs) for available classes."
    },
    {
      "type": "paragraph",
      "content": "icon block (v.1.0.0)"
    }
  ],
  "presets": [
    {
      "name": "Icon"
    },
    {
      "name": "Logo",
      "settings": {
        "height": 38,
        "height_mob": 32,
        "aspect_ratio": "auto",
        "aspect_ratio_mob": "auto",
        "placeholder": "pl--logo-placeholder.png"
      }
