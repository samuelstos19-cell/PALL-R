<style>
  /* ============================================================
     MOTH — HEADER DESIGN SYSTEM
     Nocturnal luxury · Glass-dark · Gold thread details
     ============================================================ */

  /* ── Palette & tokens ── */
  .section-header {
    --moth-void:      #0a0806;
    --moth-deep:      #110e0a;
    --moth-charcoal:  #1c1814;
    --moth-ash:       #2e2922;
    --moth-smoke:     #4a433a;
    --moth-vellum:    #e8dece;
    --moth-cream:     #f5efe4;
    --moth-dust:      #9a9080;
    --moth-gold:      #b8955a;
    --moth-gold-pale: #d4b07a;
    --moth-wing:      #3d2e1e;

    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body:    'Jost', 'Helvetica Neue', sans-serif;

    --ease-silk:   cubic-bezier(0.25, 0.1, 0.25, 1);
    --ease-emerge: cubic-bezier(0.16, 1, 0.3, 1);
    --t-mid: 300ms;
    --t-slow: 600ms;
  }

  /* ── Header wrapper ── */
  .header-wrapper {
    background-color: var(--moth-void) !important;
    background-image:
      radial-gradient(ellipse 60% 100% at 50% 0%, rgba(61, 46, 30, 0.18) 0%, transparent 70%),
      url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E") !important;
    border-bottom: 1px solid var(--moth-ash) !important;
    transition: background-color var(--t-slow) var(--ease-silk);
  }

  /* Scrolled: deepen the background slightly, reinforce gold border */
  .shopify-section-header-sticky .header-wrapper {
    background-color: rgba(10, 8, 6, 0.97) !important;
    backdrop-filter: blur(12px) saturate(0.8);
    -webkit-backdrop-filter: blur(12px) saturate(0.8);
    border-bottom-color: rgba(184, 149, 90, 0.25) !important;
    box-shadow: 0 1px 32px rgba(0, 0, 0, 0.55);
  }

  /* ── Header inner ── */
  .header {
    color: var(--moth-vellum);
    gap: 3.2rem;
  }

  /* ── Logo ── */
  .header__heading-link {
    display: inline-flex;
    align-items: center;
  }
  .header__heading-logo {
    max-width: {{ settings.logo_width }}px;
    transition: opacity var(--t-mid) var(--ease-silk), filter var(--t-mid) var(--ease-silk);
  }
  .header__heading-logo:hover {
    opacity: 0.85;
    filter: brightness(1.08);
  }

  /* Logo swap on scroll */
  .logo-swap {
    position: relative;
    display: inline-block;
  }
  .logo-default { display: block; }
  .logo-scroll  { display: none; }
  .section-header.scrolled-past-header .logo-default { display: none; }
  .section-header.scrolled-past-header .logo-scroll  { display: block; }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo {
      width: 75%;
      transition: width 0.4s var(--ease-emerge);
    }
  {%- endif -%}

  /* Fallback text logo */
  .header__heading-link .h2 {
    font-family: var(--font-display) !important;
    font-size: 2.4rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--moth-cream);
  }

  /* ── Desktop navigation ── */
  @media screen and (min-width: 990px) {
    header-drawer { display: none; }
  }

  .header__inline-menu .list-menu--inline {
    gap: 0.4rem;
  }

  /* Nav items */
  .header__menu-item,
  .header__inline-menu .list-menu__item a,
  .header__inline-menu .list-menu__item > a {
    font-family: var(--font-body) !important;
    font-size: 1.05rem !important;
    font-weight: 300 !important;
    letter-spacing: 0.22em !important;
    text-transform: uppercase !important;
    color: var(--moth-dust) !important;
    padding: 0.6rem 1.4rem !important;
    position: relative;
    transition: color var(--t-mid) var(--ease-silk) !important;
  }

  /* Animated underline on nav items */
  .header__menu-item::after,
  .header__inline-menu .list-menu__item > a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 1.4rem;
    right: 1.4rem;
    height: 1px;
    background: var(--moth-gold);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--t-mid) var(--ease-emerge);
  }
  .header__menu-item:hover::after,
  .header__inline-menu .list-menu__item > a:hover::after {
    transform: scaleX(1);
  }

  .header__menu-item:hover,
  .header__inline-menu .list-menu__item > a:hover {
    color: var(--moth-cream) !important;
  }

  /* Active / current nav item */
  .header__active-menu-item,
  .list-menu__item--active,
  [aria-current="page"] .header__active-menu-item {
    color: var(--moth-gold) !important;
  }

  /* Caret icon in nav */
  .header__menu-item .icon-caret {
    color: var(--moth-smoke);
    transition: transform var(--t-mid) var(--ease-silk), color var(--t-mid);
  }
  details[open] > summary .icon-caret {
    transform: rotate(180deg);
    color: var(--moth-gold);
  }

  /* ── Desktop dropdown submenu ── */
  .header__submenu {
    background-color: var(--moth-charcoal) !important;
    border: 1px solid var(--moth-ash) !important;
    border-top: 1px solid rgba(184, 149, 90, 0.2) !important;
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.55),
      0 1px 0 rgba(184, 149, 90, 0.08) inset !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    animation: moth-dropdown-open 0.25s var(--ease-emerge) both;
  }

  @keyframes moth-dropdown-open {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .header__submenu .header__menu-item,
  .header__submenu a.list-menu__item {
    font-family: var(--font-body) !important;
    font-size: 1.1rem !important;
    letter-spacing: 0.16em !important;
    text-transform: uppercase !important;
    font-weight: 300 !important;
    color: var(--moth-dust) !important;
    padding: 1rem 2rem !important;
    transition: color var(--t-mid), background-color var(--t-mid);
  }
  .header__submenu a.list-menu__item:hover,
  .header__submenu .header__menu-item:hover {
    color: var(--moth-gold) !important;
    background-color: rgba(184, 149, 90, 0.05) !important;
  }

  /* ── Mega menu ── */
  .mega-menu__content {
    background-color: var(--moth-charcoal) !important;
    border: 1px solid var(--moth-ash) !important;
    border-top: 1px solid rgba(184, 149, 90, 0.2) !important;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6) !important;
    animation: moth-dropdown-open 0.3s var(--ease-emerge) both;
  }
  .mega-menu__link {
    font-family: var(--font-body) !important;
    letter-spacing: 0.16em !important;
    text-transform: uppercase !important;
    font-weight: 300 !important;
    color: var(--moth-dust) !important;
    transition: color var(--t-mid);
  }
  .mega-menu__link--level-2 {
    font-family: var(--font-display) !important;
    font-size: 1.6rem !important;
    font-weight: 400 !important;
    letter-spacing: 0.08em !important;
    text-transform: none !important;
    color: var(--moth-vellum) !important;
    margin-bottom: 1.2rem;
  }
  .mega-menu__link:hover,
  .mega-menu__link--level-2:hover {
    color: var(--moth-gold) !important;
  }
  .mega-menu__link--active {
    color: var(--moth-gold) !important;
  }

  /* ── Header icons (search, account, cart) ── */
  .header__icon {
    color: var(--moth-dust) !important;
    transition: color var(--t-mid) var(--ease-silk) !important;
    position: relative;
  }
  .header__icon:hover {
    color: var(--moth-gold) !important;
  }
  .header__icon svg {
    transition: transform var(--t-mid) var(--ease-emerge);
  }
  .header__icon:hover svg {
    transform: scale(1.08);
  }

  /* Cart count bubble */
  .cart-count-bubble {
    background-color: var(--moth-gold) !important;
    color: var(--moth-void) !important;
    font-family: var(--font-body) !important;
    font-size: 0.85rem !important;
    font-weight: 500 !important;
    letter-spacing: 0.05em;
    min-width: 1.6rem;
    min-height: 1.6rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Search modal ── */
  .search-modal {
    background-color: rgba(10, 8, 6, 0.92) !important;
    backdrop-filter: blur(16px) saturate(0.8);
    -webkit-backdrop-filter: blur(16px) saturate(0.8);
  }
  .search-modal__content {
    background-color: var(--moth-charcoal) !important;
    border-bottom: 1px solid var(--moth-ash) !important;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.55) !important;
  }

  /* Search input */
  .search-modal__form .search__input,
  .search-modal__form .field__input {
    font-family: var(--font-body) !important;
    font-size: 1.6rem !important;
    font-weight: 300 !important;
    letter-spacing: 0.08em !important;
    color: var(--moth-vellum) !important;
    background-color: transparent !important;
    border-color: var(--moth-ash) !important;
    caret-color: var(--moth-gold);
  }
  .search-modal__form .field__input:focus {
    border-color: var(--moth-gold) !important;
    outline: none !important;
    box-shadow: 0 0 0 2px rgba(184, 149, 90, 0.1) !important;
  }
  .search-modal__form .field__label {
    font-family: var(--font-body) !important;
    font-size: 1.1rem !important;
    letter-spacing: 0.2em !important;
    text-transform: uppercase !important;
    color: var(--moth-smoke) !important;
    font-weight: 300 !important;
  }
  .search-modal__form .search__button,
  .search-modal__form .field__button {
    color: var(--moth-dust) !important;
    transition: color var(--t-mid);
  }
  .search-modal__form .search__button:hover,
  .search-modal__form .field__button:hover {
    color: var(--moth-gold) !important;
  }

  /* Predictive search results */
  .predictive-search {
    background-color: var(--moth-charcoal) !important;
    border: 1px solid var(--moth-ash) !important;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.55) !important;
  }
  .predictive-search__item:hover,
  .predictive-search__item--link:hover {
    background-color: rgba(184, 149, 90, 0.05) !important;
  }
  .predictive-search__item-heading {
    font-family: var(--font-display) !important;
    font-weight: 400 !important;
    color: var(--moth-cream) !important;
  }
  .predictive-search__item-vendor,
  .predictive-search__item-price {
    font-family: var(--font-body) !important;
    font-size: 1.1rem !important;
    letter-spacing: 0.08em !important;
    color: var(--moth-dust) !important;
  }
  .predictive-search .spinner .path {
    stroke: var(--moth-gold) !important;
  }

  /* Modal close button */
  .modal__close-button,
  .search-modal__close-button {
    color: var(--moth-dust) !important;
    transition: color var(--t-mid);
  }
  .modal__close-button:hover,
  .search-modal__close-button:hover {
    color: var(--moth-gold) !important;
  }

  /* ── Mobile drawer ── */
  .menu-drawer-container { display: flex; }

  .menu-drawer {
    background-color: var(--moth-charcoal) !important;
    border-right: 1px solid var(--moth-ash) !important;
  }

  /* Hamburger icon */
  .header__icon--menu {
    color: var(--moth-dust) !important;
    transition: color var(--t-mid);
  }
  .header__icon--menu:hover {
    color: var(--moth-gold) !important;
  }

  /* Drawer menu items */
  .menu-drawer__menu-item {
    font-family: var(--font-body) !important;
    font-size: 1.3rem !important;
    font-weight: 300 !important;
    letter-spacing: 0.2em !important;
    text-transform: uppercase !important;
    color: var(--moth-dust) !important;
    border-bottom: 1px solid var(--moth-ash) !important;
    padding: 1.6rem 0 !important;
    transition: color var(--t-mid), padding-left var(--t-mid) var(--ease-emerge) !important;
  }
  .menu-drawer__menu-item:hover {
    color: var(--moth-cream) !important;
    padding-left: 0.4rem !important;
  }
  .menu-drawer__menu-item--active {
    color: var(--moth-gold) !important;
  }

  /* Drawer back button */
  .menu-drawer__close-button {
    font-family: var(--font-body) !important;
    font-size: 1.1rem !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    font-weight: 300 !important;
    color: var(--moth-dust) !important;
    transition: color var(--t-mid);
  }
  .menu-drawer__close-button:hover {
    color: var(--moth-gold) !important;
  }

  /* Drawer submenu */
  .menu-drawer__submenu {
    background-color: var(--moth-deep) !important;
    border-left: 1px solid rgba(184, 149, 90, 0.15) !important;
  }

  /* Drawer utility: account link */
  .menu-drawer__account {
    font-family: var(--font-body) !important;
    font-size: 1.1rem !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    font-weight: 300 !important;
    color: var(--moth-dust) !important;
    border-top: 1px solid var(--moth-ash) !important;
    padding-top: 2rem !important;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: color var(--t-mid);
  }
  .menu-drawer__account:hover {
    color: var(--moth-gold) !important;
  }
  .menu-drawer__account svg {
    color: var(--moth-smoke);
    transition: color var(--t-mid);
  }
  .menu-drawer__account:hover svg {
    color: var(--moth-gold);
  }

  /* Social links in drawer */
  .list-social__link {
    color: var(--moth-smoke) !important;
    transition: color var(--t-mid);
  }
  .list-social__link:hover {
    color: var(--moth-gold) !important;
  }

  /* ── List menu shared ── */
  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }
  summary.list-menu__item {
    padding-right: 2.7rem;
  }
  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }
  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }
  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

  /* ── Separator line ── */
  .header-wrapper--border-bottom {
    border-bottom: 1px solid var(--moth-ash) !important;
  }

  /* ── Header entry animation ── */
  @keyframes moth-header-drop {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .header-wrapper {
    animation: moth-header-drop 0.7s var(--ease-emerge) both;
  }

  /* ── Focus visible ── */
  .focus-inset:focus-visible {
    outline: 1.5px solid var(--moth-gold) !important;
    outline-offset: -2px !important;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .section-header *,
    .section-header *::before,
    .section-header *::after,
    .header-wrapper,
    .menu-drawer,
    .search-modal,
    .header__submenu,
    .mega-menu__content {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

{%- style -%}
  .header {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px;
  }

  .section-header {
    position: sticky;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'details-modal.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'search-form.js' | asset_url }}" defer="defer"></script>
{%- if settings.cart_type == "drawer" -%}
  <script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<svg xmlns="http://www.w3.org/2000/svg" class="hidden">
  <symbol id="icon-search" viewbox="0 0 18 19" fill="none">
    <path fill-rule="evenodd" clip-rule="evenodd" d="M11.03 11.68A5.784 5.784 0 112.85 3.5a5.784 5.784 0 018.18 8.18zm.26 1.12a6.78 6.78 0 11.72-.7l5.4 5.4a.5.5 0 11-.71.7l-5.41-5.4z" fill="currentColor"/>
  </symbol>
  <symbol id="icon-reset" class="icon icon-close" fill="none" viewBox="0 0 18 18" stroke="currentColor">
    <circle r="8.5" cy="9" cx="9" stroke-opacity="0.2"/>
    <path d="M6.82972 6.82915L1.17193 1.17097" stroke-linecap="round" stroke-linejoin="round" transform="translate(5 5)"/>
    <path d="M1.22896 6.88502L6.77288 1.11523" stroke-linecap="round" stroke-linejoin="round" transform="translate(5 5)"/>
  </symbol>
  <symbol id="icon-close" class="icon icon-close" fill="none" viewBox="0 0 18 17">
    <path d="M.865 15.978a.5.5 0 00.707.707l7.433-7.431 7.579 7.282a.501.501 0 00.846-.37.5.5 0 00-.153-.351L9.712 8.546l7.417-7.416a.5.5 0 10-.707-.708L8.991 7.853 1.413.573a.5.5 0 10-.693.72l7.563 7.268-7.418 7.417z" fill="currentColor">
  </symbol>
</svg>

<{% if section.settings.sticky_header_type != 'none' %}sticky-header data-sticky-type="{{ section.settings.sticky_header_type }}"{% else %}div{% endif %} class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}">
  <header class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu != blank %} header--has-menu{% endif %}">

    {%- if section.settings.menu != blank -%}
      <header-drawer data-breakpoint="tablet">
        <details id="Details-menu-drawer-container" class="menu-drawer-container">
          <summary class="header__icon header__icon--menu header__icon--summary link focus-inset" aria-label="{{ 'sections.header.menu' | t }}">
            <span>
              {% render 'icon-hamburger' %}
              {% render 'icon-close' %}
            </span>
          </summary>
          <div id="menu-drawer" class="gradient menu-drawer motion-reduce" tabindex="-1">
            <div class="menu-drawer__inner-container">
              <div class="menu-drawer__navigation-container">
                <nav class="menu-drawer__navigation">
                  <ul class="menu-drawer__menu has-submenu list-menu" role="list">
                    {%- for link in section.settings.menu.links -%}
                      <li>
                        {%- if link.links != blank -%}
                          <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                            <summary class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}">
                              {{ link.title | escape }}
                              {% render 'icon-arrow' %}
                              {% render 'icon-caret' %}
                            </summary>
                            <div id="link-{{ link.handle | escape }}" class="menu-drawer__submenu has-submenu gradient motion-reduce" tabindex="-1">
